{
  "name": "estudafatec",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "trap 'exit 0' INT;npm run services:up && npm run services:wait:postgres && npm run migrations:up && next dev",
    "postdev": "npm run services:stop",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:postgres": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrations:up:dry": "node-pg-migrate -m infra/migrations --envPath .env.development --dry-run up",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "test": "npm run services:up && npm run services:wait:postgres && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "cookie": "1.1.1",
    "mongodb": "6.16.0",
    "next": "15.0.7",
    "next-connect": "1.0.0",
    "node": "18.18.0",
    "node-pg-migrate": "7.9.1",
    "nodemailer": "7.0.5",
    "pg": "8.20.0",
    "swr": "2.4.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@faker-js/faker": "9.7.0",
    "@tailwindcss/postcss": "4.2.4",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "16.5.0",
    "dotenv-expand": "11.0.7",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "28.11.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "postcss": "8.5.12",
    "prettier": "3.8.3",
    "set-cookie-parser": "2.7.1",
    "tailwindcss": "4.2.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": "24"
  }
}
